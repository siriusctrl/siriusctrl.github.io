---
import "@fontsource-variable/geist/wght.css";
import "@fontsource-variable/geist-mono/wght.css";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Sirius Ctrl",
  description = "Independent software projects, terminal tools, and interactive browser experiments.",
  image = "/media/freeform-artifacts.webp",
} = Astro.props;
const pageTitle = title === "Sirius Ctrl" ? title : `${title} | Sirius Ctrl`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f3ef" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Sirius Ctrl notes" href="/rss.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const saved = window.localStorage.getItem("siriusctrl.theme");
        const theme = saved === "light" || saved === "dark"
          ? saved
          : window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = theme;
        document.querySelector('meta[name="theme-color"]')?.setAttribute(
          "content",
          theme === "dark" ? "#151716" : "#f3f3ef",
        );
      })();
    </script>
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
    <script>
      type ThemeTransition = {
        ready: Promise<void>;
        finished: Promise<void>;
      };

      const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const transitionDocument = document as Document & {
        startViewTransition?: (update: () => void) => ThemeTransition;
      };

      toggle?.addEventListener("click", (event) => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        const applyTheme = () => {
          document.documentElement.dataset.theme = next;
          document.querySelector<HTMLMetaElement>('meta[name="theme-color"]')?.setAttribute(
            "content",
            next === "dark" ? "#151716" : "#f3f3ef",
          );
          window.localStorage.setItem("siriusctrl.theme", next);
          const label = `Switch to ${next === "dark" ? "light" : "dark"} mode`;
          toggle.setAttribute("aria-label", label);
          toggle.setAttribute("title", label);
        };

        if (!transitionDocument.startViewTransition || reducedMotion.matches) {
          applyTheme();
          return;
        }

        const bounds = toggle.getBoundingClientRect();
        const x = event.detail > 0 ? event.clientX : bounds.left + bounds.width / 2;
        const y = event.detail > 0 ? event.clientY : bounds.top + bounds.height / 2;
        const radius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y),
        );
        const transition = transitionDocument.startViewTransition(applyTheme);
        document.documentElement.dataset.themeTransition = "active";

        transition.ready
          .then(() => {
            document.documentElement.animate(
              [
                { clipPath: `circle(0 at ${x}px ${y}px)`, offset: 0 },
                { clipPath: `circle(18px at ${x}px ${y}px)`, offset: 0.12 },
                { clipPath: `circle(${radius}px at ${x}px ${y}px)`, offset: 1 },
              ],
              {
                duration: 720,
                easing: "ease-in",
                pseudoElement: "::view-transition-new(root)",
              } as KeyframeAnimationOptions & { pseudoElement: string },
            );
          })
          .catch(() => undefined);

        const clearTransitionState = () => {
          delete document.documentElement.dataset.themeTransition;
        };
        transition.finished.then(clearTransitionState, clearTransitionState);
      });
    </script>
  </body>
</html>
