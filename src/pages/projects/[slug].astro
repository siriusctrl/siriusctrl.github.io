---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import ProjectArtwork from "../../components/ProjectArtwork.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
---

<BaseLayout title={project.name} description={project.summary} image={project.image}>
  <main class="page-shell project-detail">
    <header class="project-detail-header">
      <div class="project-meta"><span>{project.kind}</span><span>{project.year}</span></div>
      <h1>{project.name}</h1>
      <p>{project.summary}</p>
      <div class="detail-actions">
        {project.demoUrl && (
          <a class="button button-primary" href={project.demoUrl}>
            Open demo <Icon name="arrow-up-right" />
          </a>
        )}
        <a class="button button-outline" href={project.repoUrl}>
          View source <Icon name="arrow-up-right" />
        </a>
      </div>
    </header>
    <ProjectArtwork project={project} eager class="detail-artwork" />
    <section class="project-detail-body">
      <div>
        <h2>What it does</h2>
        <p>{project.detail}</p>
      </div>
      <aside>
        <h2>Built with</h2>
        <div class="stack-list">{project.stack.map((item) => <span>{item}</span>)}</div>
        {project.install && (
          <div class="install-block">
            <span>Install or start</span>
            <code>{project.install}</code>
          </div>
        )}
      </aside>
    </section>
  </main>
</BaseLayout>
