---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import ProjectArtwork from "../components/ProjectArtwork.astro";
import { projects } from "../data/projects";
import { getCollection } from "astro:content";

const featuredProjects = projects.filter((project) => project.featured);
if (featuredProjects.length !== 1) throw new Error("Home page requires exactly one featured project");
const featuredProject = featuredProjects[0];
const recentProjects = projects.filter((project) => project !== featuredProject);
const workProjects = [featuredProject, ...recentProjects];
const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <main class="home-page">
    <section class="home-intro" aria-labelledby="hero-title">
      <div class="intro-rail">
        <p>Independent software</p>
        <p>Built in public</p>
      </div>
      <h1 id="hero-title">
        Software for seeing
        <span>what systems are doing.</span>
      </h1>
      <div class="intro-bottom">
        <p class="intro-statement">
          I turn complicated ideas into working software: things you can run, inspect, and play with.
        </p>
        <div class="intro-links" aria-label="Homepage links">
          <a href="/projects/">View projects <Icon name="arrow-right" /></a>
          <a href="https://github.com/siriusctrl">
            GitHub <Icon name="arrow-up-right" />
          </a>
        </div>
      </div>
    </section>

    <section class="section recent-work" aria-labelledby="recent-title">
      <div class="work-heading">
        <h2 id="recent-title">Recent work</h2>
        <p>Working software, recorded in the environment where it actually runs.</p>
      </div>

      <div class="work-stage" data-work-stage>
        <div class="work-visual" aria-hidden="true">
          <div class="work-visual-sticky">
            {workProjects.map((project, index) => (
              <div
                class:list={["work-frame", { "is-active": index === 0 }]}
                data-work-frame={project.slug}
              >
                <ProjectArtwork project={project} eager={index === 0} />
              </div>
            ))}
          </div>
        </div>
        <div class="work-entries">
          {workProjects.map((project, index) => (
            <article
              class:list={["work-entry", { "is-active": index === 0 }]}
              data-work-entry={project.slug}
            >
              <a
                class="work-entry-media"
                href={`/projects/${project.slug}/`}
                tabindex="-1"
                aria-hidden="true"
              >
                <ProjectArtwork project={project} />
              </a>
              <div class="project-meta"><span>{project.kind}</span><span>{project.year}</span></div>
              <h3><a href={`/projects/${project.slug}/`}>{project.name}</a></h3>
              <p>{project.summary}</p>
              {project.demoUrl && (
                <a class="work-demo-link" href={project.demoUrl}>
                  Open demo <Icon name="arrow-up-right" />
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section notes-preview" aria-labelledby="notes-title">
      <div class="section-heading compact-heading">
        <h2 id="notes-title">Notes</h2>
        <p>Architecture choices, experiments, and the reasoning that survives the commit.</p>
      </div>
      <div class="note-list">
        {notes.map((note) => (
          <a class="note-row" href={`/notes/${note.id}/`}>
            <time datetime={note.data.publishedAt.toISOString()}>
              {note.data.publishedAt.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}
            </time>
            <span>
              <strong>{note.data.title}</strong>
              <small>{note.data.description}</small>
            </span>
            <Icon name="arrow-right" />
          </a>
        ))}
      </div>
      <a class="text-link" href="/notes/">All notes <Icon name="arrow-right" /></a>
    </section>
  </main>
</BaseLayout>

<script>
  const workStage = document.querySelector<HTMLElement>("[data-work-stage]");
  const workEntries = Array.from(document.querySelectorAll<HTMLElement>("[data-work-entry]"));
  const workFrames = Array.from(document.querySelectorAll<HTMLElement>("[data-work-frame]"));
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  let isWorkAnimating = false;

  const activateWork = (slug: string) => {
    workEntries.forEach((entry) => entry.classList.toggle("is-active", entry.dataset.workEntry === slug));
    workFrames.forEach((frame) => frame.classList.toggle("is-active", frame.dataset.workFrame === slug));
  };

  if (workStage && workEntries.length > 0 && workFrames.length > 0) {
    document.documentElement.classList.add("has-work-snap");
    const workObserver = new IntersectionObserver(
      (observations) => {
        if (isWorkAnimating) return;
        const visible = observations
          .filter((observation) => observation.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        const slug = (visible[0]?.target as HTMLElement | undefined)?.dataset.workEntry;
        if (slug) activateWork(slug);
      },
      { rootMargin: "-38% 0px -38% 0px", threshold: [0, 0.25, 0.5] },
    );

    workEntries.forEach((entry) => {
      workObserver.observe(entry);
      entry.addEventListener("focusin", () => {
        if (!isWorkAnimating && entry.dataset.workEntry) activateWork(entry.dataset.workEntry);
      });
    });

    const intentThreshold = 140;
    let wheelIntent = 0;
    let lastWheelAt = 0;
    let reboundTimer: number | undefined;
    let settleClassTimer: number | undefined;
    let cooldownUntil = 0;

    const setWorkPull = (pixels: number) => {
      workStage.style.setProperty("--work-pull", `${pixels.toFixed(2)}px`);
      workStage.style.setProperty("--work-visual-pull", `${(pixels * 0.16).toFixed(2)}px`);
    };

    const clearSettleClass = () => {
      if (settleClassTimer) window.clearTimeout(settleClassTimer);
      settleClassTimer = window.setTimeout(() => {
        workStage.classList.remove("is-wheel-settling");
        document.documentElement.classList.remove("is-work-resisting");
      }, 560);
    };

    const reboundWork = () => {
      wheelIntent = 0;
      lastWheelAt = 0;
      workStage.classList.remove("is-wheel-pulling");
      workStage.classList.add("is-wheel-settling");
      window.requestAnimationFrame(() => setWorkPull(0));
      clearSettleClass();
    };

    const nearestWorkEntry = () => {
      const viewportCenter = window.innerHeight / 2;
      return workEntries
        .map((entry, index) => {
          const bounds = entry.getBoundingClientRect();
          return { index, distance: bounds.top + bounds.height / 2 - viewportCenter };
        })
        .sort((a, b) => Math.abs(a.distance) - Math.abs(b.distance))[0];
    };

    const entryScrollTarget = (entry: HTMLElement) => {
      const bounds = entry.getBoundingClientRect();
      const transform = getComputedStyle(entry).transform;
      const transformY = transform === "none" ? 0 : new DOMMatrixReadOnly(transform).m42;
      const target = window.scrollY + bounds.top + bounds.height / 2 - transformY - window.innerHeight / 2;
      return Math.max(0, Math.min(target, document.documentElement.scrollHeight - window.innerHeight));
    };

    const moveToWorkEntry = (index: number) => {
      const entry = workEntries[index];
      const slug = entry?.dataset.workEntry;
      if (!entry || !slug) return;

      if (reboundTimer) window.clearTimeout(reboundTimer);
      wheelIntent = 0;
      lastWheelAt = 0;
      isWorkAnimating = true;
      document.documentElement.classList.add("is-work-animating");
      workStage.classList.remove("is-wheel-pulling");
      workStage.classList.add("is-wheel-settling");
      setWorkPull(0);
      clearSettleClass();

      let position = window.scrollY;
      const start = position;
      const target = entryScrollTarget(entry);
      const travel = target - start;
      let velocity = 0;
      let previousTime = performance.now();
      let targetActivated = false;
      const startedAt = previousTime;

      const finish = () => {
        window.scrollTo(0, target);
        activateWork(slug);
        isWorkAnimating = false;
        cooldownUntil = performance.now() + 180;
        document.documentElement.classList.remove("is-work-animating");
      };

      const step = (time: number) => {
        const elapsed = time - startedAt;
        const deltaTime = Math.min((time - previousTime) / 1000, 0.032);
        previousTime = time;

        const angularFrequency = 12;
        const dampingRatio = 0.84;
        const acceleration = angularFrequency ** 2 * (target - position)
          - 2 * dampingRatio * angularFrequency * velocity;
        velocity += acceleration * deltaTime;
        position += velocity * deltaTime;
        window.scrollTo(0, position);

        const progress = travel === 0 ? 1 : Math.abs((position - start) / travel);
        if (!targetActivated && progress > 0.38) {
          activateWork(slug);
          targetActivated = true;
        }

        if ((Math.abs(target - position) < 0.5 && Math.abs(velocity) < 5) || elapsed > 1100) {
          finish();
          return;
        }
        window.requestAnimationFrame(step);
      };

      window.requestAnimationFrame(step);
    };

    window.addEventListener("wheel", (event) => {
      if (
        reducedMotion.matches
        || window.innerWidth <= 860
        || event.ctrlKey
        || Math.abs(event.deltaY) <= Math.abs(event.deltaX)
      ) return;

      const stageBounds = workStage.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      if (stageBounds.top > viewportCenter || stageBounds.bottom < viewportCenter) return;

      if (isWorkAnimating) {
        event.preventDefault();
        cooldownUntil = performance.now() + 180;
        return;
      }

      const nearest = nearestWorkEntry();
      if (!nearest || Math.abs(nearest.distance) > 28) return;

      const scale = event.deltaMode === WheelEvent.DOM_DELTA_LINE
        ? 16
        : event.deltaMode === WheelEvent.DOM_DELTA_PAGE
          ? window.innerHeight
          : 1;
      const delta = event.deltaY * scale;
      const direction = Math.sign(delta);
      const now = performance.now();
      if (now < cooldownUntil) {
        event.preventDefault();
        cooldownUntil = now + 180;
        return;
      }
      const leavingStage = (direction < 0 && nearest.index === 0)
        || (direction > 0 && nearest.index === workEntries.length - 1);
      if (leavingStage) {
        reboundWork();
        return;
      }

      event.preventDefault();

      if (now - lastWheelAt > 180 || (wheelIntent !== 0 && Math.sign(wheelIntent) !== direction)) {
        wheelIntent = 0;
      }
      lastWheelAt = now;
      wheelIntent += Math.max(-220, Math.min(220, delta));

      if (Math.abs(wheelIntent) >= intentThreshold) {
        moveToWorkEntry(nearest.index + direction);
        return;
      }

      if (reboundTimer) window.clearTimeout(reboundTimer);
      workStage.classList.remove("is-wheel-settling");
      workStage.classList.add("is-wheel-pulling");
      document.documentElement.classList.add("is-work-resisting");
      const pull = -Math.sign(wheelIntent)
        * 16
        * (1 - Math.exp(-Math.abs(wheelIntent) / 70));
      setWorkPull(pull);
      reboundTimer = window.setTimeout(reboundWork, 140);
    }, { passive: false });
  }
</script>
