---
import Icon from "./Icon.astro";

const path = Astro.url.pathname;
const nav = [
  { href: "/projects/", label: "Projects" },
  { href: "/notes/", label: "Notes" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Sirius Ctrl home">Sirius Ctrl</a>
  <nav aria-label="Primary navigation">
    {nav.map((item) => (
      <a href={item.href} aria-current={path.startsWith(item.href) ? "page" : undefined}>{item.label}</a>
    ))}
    <a class="github-link" href="https://github.com/siriusctrl">GitHub</a>
    <button
      class="icon-button"
      type="button"
      data-theme-toggle
      data-testid="theme-toggle"
      aria-label="Switch color mode"
      title="Switch color mode"
    >
      <Icon name="moon" class="theme-moon" />
      <Icon name="sun" class="theme-sun" />
    </button>
  </nav>
</header>
