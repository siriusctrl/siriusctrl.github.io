---
const path = Astro.url.pathname;
const nav = [
  { href: "/projects/", label: "Projects" },
  { href: "/notes/", label: "Notes" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Sirius Ctrl home">Sirius Ctrl</a>
  <nav aria-label="Primary navigation">
    {nav.map((item) => (
      <a href={item.href} aria-current={path.startsWith(item.href) ? "page" : undefined}>{item.label}</a>
    ))}
    <a class="icon-link" href="https://github.com/siriusctrl" aria-label="GitHub profile" title="GitHub">
      <i class="ph ph-github-logo" aria-hidden="true"></i>
    </a>
    <button
      class="icon-button"
      type="button"
      data-theme-toggle
      data-testid="theme-toggle"
      aria-label="Switch color mode"
      title="Switch color mode"
    >
      <i class="ph ph-moon theme-moon" aria-hidden="true"></i>
      <i class="ph ph-sun theme-sun" aria-hidden="true"></i>
    </button>
  </nav>
</header>
