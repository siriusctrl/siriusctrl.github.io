---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  eager?: boolean;
  class?: string;
}

const { project, eager = false, class: className = "" } = Astro.props;
---

<figure class:list={["project-artwork", `tone-${project.tone}`, className]}>
  <img
    src={project.image}
    alt={project.imageAlt}
    width="1600"
    height="1000"
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
  />
</figure>
