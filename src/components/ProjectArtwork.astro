---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  eager?: boolean;
  variant?: "portrait" | "runtime";
  class?: string;
}

const { project, eager = false, variant = "portrait", class: className = "" } = Astro.props;
const source = variant === "portrait" ? project.portrait : project.image;
const alt = variant === "portrait" ? project.portraitAlt : project.imageAlt;
const hasPortraitArt = source === project.portrait;
---

<figure class:list={["project-artwork", `is-${variant}`, { "has-portrait-art": hasPortraitArt }, className]}>
  <img
    src={source}
    alt={alt}
    width="1600"
    height="1000"
    loading={eager ? "eager" : "lazy"}
    fetchpriority={eager ? "high" : "auto"}
  />
</figure>
